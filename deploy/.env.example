# =============================================================================
# 云服务器「venv 部署」配置（与 backend/.env 是两份文件）
# 用法：cp deploy/.env.example deploy/.env  然后 vim deploy/.env
# 完整教程：docs/部署/B-云服务器-venv-SQLite.md （或 C）
# 变量说明：docs/部署/环境变量说明.md
# =============================================================================

# 公网 IP 或域名（不要写 http://）
# 前端构建时写入，浏览器会请求 http://PUBLIC_HOST:BACKEND_PORT
PUBLIC_HOST=127.0.0.1

BACKEND_PORT=5000
FRONTEND_PORT=3000

# Python 虚拟环境目录
# 留空 = 使用项目内 backend/.venv（没有则自动创建）
# 已有 venv 时填写绝对路径，例如：
# VENV_DIR=/home/ubuntu/.venv-vita
VENV_DIR=
