# =============================================================================
# Vita 后端环境变量模板
# 用法：cp backend/.env.example backend/.env  然后 vim backend/.env
# 完整说明（数据库安装 / 多种部署）：docs/部署教程.md
# =============================================================================

# ---------- 安全（上线必改）----------
# 可用命令生成：openssl rand -hex 32
SECRET_KEY=change-me
JWT_SECRET=change-me-too
JWT_EXPIRES_HOURS=24

# ---------- 数据库 ----------
# 留空 = SQLite 文件 backend/vita.db（本机开发 / 快速演示推荐）
DATABASE_URL=
#
# 同机 PostgreSQL 示例（先按 docs/部署教程.md §4 建库建用户）：
# DATABASE_URL=postgresql://vita:你的强密码@127.0.0.1:5432/vita
#
# Docker Compose + Postgres 时（服务名 db，见 docker-compose.postgres.yml）：
# DATABASE_URL=postgresql://vita:你的强密码@db:5432/vita
#
# 注意：换库不会自动迁移旧数据，等于空库，需重新注册。

# ---------- AI（可选；也可在网页「设置」里配置）----------
# openai = OpenAI 兼容（含 DeepSeek 等）；anthropic = Anthropic 原生
AI_PROVIDER=openai
AI_API_KEY=

# OpenAI / DeepSeek 等兼容端点：
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
# DeepSeek 示例：
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat

# Anthropic 示例：
# AI_PROVIDER=anthropic
# AI_API_KEY=sk-ant-...
# AI_MODEL=claude-3-5-haiku-latest
# AI_BASE_URL=

# 兼容旧变量名（可选，优先读 AI_API_KEY）
# DEEPSEEK_API_KEY=

# ---------- 提醒推送（Server酱为可选通道；浏览器弹窗不依赖此处）----------
NOTIFY_DISPATCH_INTERVAL=60
NOTIFY_CRON_SECRET=

# ---------- CORS ----------
# 测试可用 * ；正式可写 http://公网IP:3000 或 https://你的域名
CORS_ORIGINS=*

# ---------- 快速对照 ----------
# 本机开发：DATABASE_URL 留空 → python app.py
# 云服务器 venv：再配 ../deploy/.env 的 PUBLIC_HOST → ./deploy/venv-setup.sh && ./deploy/venv-start.sh
# Docker：见 docs/部署教程.md 方式 D / E
