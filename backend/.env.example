# 后端环境变量模板：复制为 .env 后填写（.env 已被 .gitignore 忽略）

# Flask / JWT 密钥（上线务必改成随机长串）
SECRET_KEY=change-me
JWT_SECRET=change-me-too
JWT_EXPIRES_HOURS=24

# 数据库：本地 / venv 部署留空 → SQLite（backend/vita.db）
# 正式可填：postgresql://user:pass@host:5432/vita
DATABASE_URL=

# AI（用户也可在网页「设置」里覆盖；服务器默认兜底）
AI_PROVIDER=openai
AI_API_KEY=

# OpenAI 兼容示例（AI_PROVIDER=openai）：
#   AI_BASE_URL=https://api.openai.com/v1
#   AI_MODEL=gpt-4o-mini
# DeepSeek 示例：
#   AI_BASE_URL=https://api.deepseek.com
#   AI_MODEL=deepseek-chat
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Anthropic 示例（AI_PROVIDER=anthropic）：
#   AI_API_KEY=sk-ant-...
#   AI_MODEL=claude-3-5-haiku-latest
#   AI_BASE_URL=   # 留空即可；代理/中转时填写

# 兼容旧变量名（可选，优先读 AI_API_KEY）
# DEEPSEEK_API_KEY=

# Server酱·Turbo 微信推送（https://sct.ftqq.com ）
# 用户在「我的」页自行绑定 SendKey，服务器无需 Token
# 后台扫描到期提醒间隔（秒），0 表示关闭
NOTIFY_DISPATCH_INTERVAL=60
# 可选：外部 cron 调用 POST /api/serverchan/dispatch 时带 Header X-Cron-Secret
NOTIFY_CRON_SECRET=

CORS_ORIGINS=*

# ---------- 云服务器提示 ----------
# 1) 复制本文件为 backend/.env 后改 SECRET_KEY / JWT_SECRET
# 2) 再配置 deploy/.env 里的 PUBLIC_HOST（公网 IP）
# 3) ./deploy/venv-setup.sh && ./deploy/venv-start.sh
