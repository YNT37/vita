# 后端环境变量模板：复制为 .env 后填写（.env 已被 .gitignore 忽略）

# Flask / JWT 密钥（上线务必改成随机长串）
SECRET_KEY=change-me
JWT_SECRET=change-me-too
JWT_EXPIRES_HOURS=24

# 数据库：本地开发留空即用 SQLite（backend/vita.db）
DATABASE_URL=

# AI 接口类型：openai（OpenAI 兼容）/ anthropic（Anthropic 原生）
AI_PROVIDER=openai
AI_API_KEY=

# OpenAI 兼容示例（AI_PROVIDER=openai）：
#   AI_BASE_URL=https://api.openai.com/v1
#   AI_MODEL=gpt-4o-mini
# DeepSeek 示例：
#   AI_BASE_URL=https://api.deepseek.com
#   AI_MODEL=deepseek-chat
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Anthropic 示例（AI_PROVIDER=anthropic）：
#   AI_API_KEY=sk-ant-...
#   AI_MODEL=claude-3-5-haiku-latest
#   AI_BASE_URL=   # 留空即可；代理/中转时填写

# 兼容旧变量名（可选，优先读 AI_API_KEY）
# DEEPSEEK_API_KEY=

# WxPusher 微信推送（https://wxpusher.zjiecode.com ）
# 1. 注册并创建应用，把 appToken 填到下面
# 2. 用户在「我的」扫码绑定或填写 UID
# 3. 到期提醒会自动推送到微信（默认每 60 秒扫描一次）
WXPUSHER_APP_TOKEN=
WXPUSHER_DISPATCH_INTERVAL=60
# 可选：外部 cron 调用 POST /api/wxpusher/dispatch 时带 Header X-Cron-Secret
WXPUSHER_CRON_SECRET=

CORS_ORIGINS=*
