# =============================================================================
# Vita 后端环境变量模板
# 用法：cp backend/.env.example backend/.env && vim backend/.env
# 部署说明：docs/部署/README.md 、 docs/部署/环境变量.md
# =============================================================================

# ---------- 安全（上线必改）----------
# openssl rand -hex 32
SECRET_KEY=change-me
JWT_SECRET=change-me-too
JWT_EXPIRES_HOURS=24

# ---------- 数据库 ----------
# Docker 默认 SQLite：留空即可（compose 会写入容器数据卷）
DATABASE_URL=
#
# Docker + Postgres（docker-compose.postgres.yml，主机名必须是 db）：
# DATABASE_URL=postgresql://vita:你的强密码@db:5432/vita
# 密码须与 deploy/postgres.env 中 POSTGRES_PASSWORD 一致
#
# 本机开发不用 Docker、直连本机 Postgres：
# DATABASE_URL=postgresql://vita:密码@127.0.0.1:5432/vita
#
# 换库不会迁移数据，需重新注册。

# ---------- AI（可选；也可在网页「设置」配置）----------
AI_PROVIDER=openai
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
# DeepSeek：
# AI_BASE_URL=https://api.deepseek.com
# AI_MODEL=deepseek-chat
# Anthropic：
# AI_PROVIDER=anthropic
# AI_API_KEY=sk-ant-...
# AI_MODEL=claude-3-5-haiku-latest
# AI_BASE_URL=
# DEEPSEEK_API_KEY=

# ---------- 提醒（Server酱可选；浏览器通知不依赖）----------
NOTIFY_DISPATCH_INTERVAL=60
NOTIFY_CRON_SECRET=

# ---------- CORS ----------
# Docker + Caddy 同域反代：保持 *
CORS_ORIGINS=*

# ---------- 部署 ----------
# 本地：docs/部署/本地-Docker.md → docker compose up -d --build
# 云服务器：docs/部署/云服务器-Docker.md
