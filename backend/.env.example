# 后端环境变量模板：复制为 .env 后填写（.env 已被 .gitignore 忽略）

# Flask / JWT 密钥（上线务必改成随机长串）
SECRET_KEY=change-me
JWT_SECRET=change-me-too
JWT_EXPIRES_HOURS=24

# 数据库：本地开发留空即用 SQLite（backend/vita.db）
# 线上 PostgreSQL 示例：postgresql://user:pass@host:5432/vita
DATABASE_URL=

# DeepSeek（Day2 的 AI 功能才用，Day1 可留空）
DEEPSEEK_API_KEY=

# 允许的前端来源，逗号分隔；开发期可用 *
CORS_ORIGINS=*
